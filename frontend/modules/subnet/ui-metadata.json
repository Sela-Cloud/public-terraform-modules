{
  "$schema": "../../ui-metadata.schema.json",
  "module": "subnet",
  "version": "1.0.0",
  "display": {
    "label": "Subnet",
    "icon": "subnet",
    "description": "Regional IPv4 subnets for custom-mode VPCs",
    "category": "regional"
  },
  "globals": [
    { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "placeholder": "my-gcp-project" }
  ],
  "resource": {
    "variable": "subnet",
    "key_field": "name",
    "key_label": "Subnet name",
    "sections": [
      {
        "id": "basic",
        "label": "Subnet configuration",
        "fields": [
          { "id": "name", "label": "Subnet name", "type": "text", "required": true, "validation": { "pattern": "^[a-z]([-a-z0-9]*[a-z0-9])?$", "pattern_error": "Use an RFC 1035 name." } },
          { "id": "region", "label": "Region", "type": "select", "required": true, "data_source": { "resource": "compute.regions", "params": { "project_id": { "from_field": "project_id" } }, "display": { "value_key": "name", "label_key": "name", "description_key": "description" }, "cache_ttl": 300 } },
          { "id": "network", "label": "VPC network", "type": "select", "required": true, "data_source": { "resource": "compute.networks", "params": { "project_id": { "from_field": "project_id" } }, "display": { "value_key": "name", "label_key": "name" }, "allow_custom": true, "cache_ttl": 300 } },
          { "id": "ip_cidr_range", "label": "Primary IPv4 CIDR", "type": "text", "required": true, "placeholder": "10.10.0.0/24", "validation": { "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/([0-9]|[12][0-9]|3[0-2])$", "pattern_error": "Enter an IPv4 CIDR, for example 10.10.0.0/24." } },
          { "id": "description", "label": "Description", "type": "text", "default": "" },
          { "id": "private_ip_google_access", "label": "Private Google Access", "type": "boolean", "default": false },
          { "id": "flow_logs", "label": "Enable VPC Flow Logs", "type": "boolean", "default": false },
          { "id": "purpose", "label": "Subnet purpose", "type": "select", "default": "PRIVATE", "options": [{ "value": "PRIVATE", "label": "Private" }, { "value": "REGIONAL_MANAGED_PROXY", "label": "Regional managed proxy" }, { "value": "GLOBAL_MANAGED_PROXY", "label": "Global managed proxy" }] },
          { "id": "stack_type", "label": "IP stack type", "type": "select", "default": "IPV4_ONLY", "options": [{ "value": "IPV4_ONLY", "label": "IPv4 only" }, { "value": "IPV4_IPV6", "label": "Dual stack" }, { "value": "IPV6_ONLY", "label": "IPv6 only" }] },
          { "id": "ipv6_access_type", "label": "IPv6 access type", "type": "select", "options": [{ "value": "INTERNAL", "label": "Internal" }, { "value": "EXTERNAL", "label": "External" }], "depends_on": { "field": "stack_type", "value": "IPV4_IPV6" } }
        ]
      },
      {
        "id": "flow_log_details",
        "label": "Flow log details",
        "collapsed": true,
        "fields": [
          { "id": "flow_logs_aggregation_interval", "label": "Aggregation interval", "type": "select", "default": "INTERVAL_5_SEC", "options": [{ "value": "INTERVAL_5_SEC", "label": "5 seconds" }, { "value": "INTERVAL_30_SEC", "label": "30 seconds" }, { "value": "INTERVAL_1_MIN", "label": "1 minute" }, { "value": "INTERVAL_5_MIN", "label": "5 minutes" }, { "value": "INTERVAL_10_MIN", "label": "10 minutes" }, { "value": "INTERVAL_15_MIN", "label": "15 minutes" }], "depends_on": { "field": "flow_logs", "value": true } },
          { "id": "flow_logs_sampling", "label": "Flow sampling", "type": "number", "default": 0.5, "validation": { "min": 0, "max": 1 }, "depends_on": { "field": "flow_logs", "value": true } },
          { "id": "flow_logs_metadata", "label": "Metadata", "type": "select", "default": "INCLUDE_ALL_METADATA", "options": [{ "value": "INCLUDE_ALL_METADATA", "label": "Include all" }, { "value": "EXCLUDE_ALL_METADATA", "label": "Exclude all" }, { "value": "CUSTOM_METADATA", "label": "Custom" }], "depends_on": { "field": "flow_logs", "value": true } }
        ]
      },
      {
        "id": "secondary",
        "label": "Secondary IP ranges",
        "collapsed": true,
        "fields": [
          { "id": "secondary_ip_ranges", "label": "Secondary ranges", "type": "repeatable", "default": [], "fields": [
            { "id": "range_name", "label": "Range name", "type": "text", "required": true },
            { "id": "ip_cidr_range", "label": "IPv4 CIDR", "type": "text", "required": true, "placeholder": "10.20.0.0/16" }
          ] }
        ]
      }
    ]
  }
}
